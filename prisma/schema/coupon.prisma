model Coupon {
  id         String   @id @default(uuid())
  code       String   @unique
  type       String   // "Percentage" | "Fixed Amount" | "Free Shipping"
  value      String   // e.g. "20%", "$15.00", "Standard"
  usageUsed  Int      @default(0)
  usageMax   Int      @default(-1) // -1 represents Infinity
  expiryDate String   @default("Never") // "Never" or Date format e.g. "Dec 31, 2024"
  status     String   @default("Active") // "Active" | "Expired" | "Scheduled"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
