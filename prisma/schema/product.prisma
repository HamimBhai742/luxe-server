model Product {
  id             String   @id @default(uuid())
  name           String
  description    String
  category       String
  brand          String?
  sku            String   @unique
  barcode        String?
  inventoryType  String   @default("tracked") // "tracked" | "untracked"
  inventoryCount Int      @default(0)
  price          Float
  originalPrice  Float?
  image          String
  images         String[] @default([])
  status         String   @default("Published") // "Published" | "Draft" | "Out of Stock"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  wishlist       WishlistItem[]
  cartItems      CartItem[]
}
