model User {
  id         String    @id @default(uuid())
  email      String    @unique
  name       String
  password   String?
  role       String    @default("user")
  isVerified Boolean   @default(false)
  otp        String?
  otpExpiry  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}
